\par \pard\plain \s18\loch\sl276\slmult1\sb0\sa140{\listtext\pard\plain \rtlch\af6 \ltrch\hich\af6\loch\f6\dbch\af6 \u57352\'3f\tab}\ilvl0\ls252 \fi-283\li0\lin0\tx709\fi-283\li709\lin709\ri0\rin0\sb0\sa0\ltrpar{\hich\af4\loch\cf1\f4\loch
