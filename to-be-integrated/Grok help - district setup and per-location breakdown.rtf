\par \pard\plain \s17\loch\sl276\slmult1\sb0\sa140{\listtext\pard\plain \rtlch\af5 \ltrch\hich\af5\loch\f5\dbch\af5 \u57352\'3f\tab}\ilvl0\ls32 \fi-283\li0\lin0\tx709\fi-283\li709\lin709\ri0\rin0\sb0\sa0\ltrpar{\hich\af4\loch\cf1\f4\loch
